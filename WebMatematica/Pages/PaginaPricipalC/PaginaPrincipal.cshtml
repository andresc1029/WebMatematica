@page "/PaginaPrincipal"
@using WebMatematica.Pages.Multiplicaciones
@model IndexModel
@{
    ViewData["Title"] = "";
}




<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="~/css/PaginaPrincipal.css" />

<!-- Hero Section -->
<section id="inicio" class="hero-section d-flex align-items-center">
    <div class="container text-center">
        <h1 class="display-1 fw-bold hero-title">La <span class="highlight">Cúpula</span></h1>
        <h5 class="mb-3 hero-subtitle">Desafía tu mente, domina la lógica y las matemáticas</h5>
        <p class="lead hero-lead">
            Bienvenido a la plataforma para potenciar tu
            <strong>razonamiento lógico-matemático</strong>.
            Encuentra ejercicios, desafíos y recursos para mejorar tus habilidades.
        </p>

        <ul class="list-unstyled mb-4">
            <li> Ejercicios interactivos</li>
            <li> Retos de lógica y razonamiento</li>
        </ul>

        <div class="d-flex justify-content-center gap-3 hero-buttons">
            <a href="/Multiplicaciones" class="btn btn-primary btn-lg shadow-lg">Multiplicaciones</a>
            <a href="#logica" class="btn btn-outline-primary btn-lg shadow-lg btn-scroll">Lógica</a>
            <a href="/Pronto" class="btn btn-outline-primary btn-lg shadow-lg">Más ejercicios</a>
        </div>
    </div>

</section>


<section id="logica" class="logic-section py-5">
    <div class="container">
        <div class="row align-items-center gy-4">
            <!-- Texto a la izquierda -->
            <div class="col-md-7 text-center text-md-start logic-text">
                <h2 class="logic-title display-4 fw-bold mb-3">Ejercicios de <span class="highlight">Lógica</span></h2>
                <h5 class="logic-subtitle mb-3">Pon a prueba tu razonamiento, encuentra patrones</h5>
                <p class="logic-lead mb-3">
                    Aquí encontrarás diferentes tipos de ejercicios para mejorar tu lógica y habilidades matemáticas.
                </p>

                <ul class="list-unstyled mb-4">
                    <li>Secuencias y patrones</li>
                    <li>Problemas con condiciones</li>
                    <li>Retos visuales</li>
                </ul>

                <div class="d-flex flex-wrap justify-content-md-start justify-content-center gap-2 logic-buttons">
                    <a href="/SecuenciasNumericas" class="btn btn-dark btn-sm shadow-sm">Secuencias Numéricas</a>
                    <a href="/Condiciones" class="btn btn-dark btn-sm shadow-sm">Problemas con Condiciones</a>
                    <a href="/PatronesVisuales" class="btn btn-dark btn-sm shadow-sm">Patrones Visuales</a>
                </div>
            </div>

            <!-- Imagen -->
            <div class="col-md-5 text-center">
                <img src="~/imagenes/logo2.png" alt="Matemáticas" class="img-fluid rounded mx-auto d-block logic-img animate-float">
            </div>
        </div>
    </div>
</section>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Js Animaciones -->
<script>
    document.querySelectorAll('.btn-scroll').forEach(btn => {
        btn.addEventListener('click', e => {
            e.preventDefault();
            const target = document.querySelector(btn.getAttribute('href'));
            target.scrollIntoView({ behavior: 'smooth' });
        });
    });

        document.addEventListener("DOMContentLoaded", function() {
        const logicText = document.querySelector(".logic-text");

        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    entry.target.classList.add("active");
                }
            });
        }, { threshold: 0.3 });

        observer.observe(logicText);
    });
</script>

<script src="~/js/logica.js"></script>
